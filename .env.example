# Discord Bot Token (required)
# Get from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_token_here

# Database URL (required for production)
# Local: postgresql+asyncpg://user:password@localhost:5432/discord_util_bot
# Heroku: automatically set by Heroku Postgres addon
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/discord_util_bot

# Web Admin Initial Credentials
# These are used to create the first admin user
# You MUST change the password on first login
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Bot runtime options
TIMEZONE_OFFSET=9
LOG_LEVEL=INFO

# Session Secret Key (auto-generated if not set)
# For production, set a strong random value
SESSION_SECRET_KEY=

# Base URL for API-side links in emails (password reset / email change)
# Example: https://admin.example.com
APP_URL=http://localhost:8000

# Base URL for ticket links posted to Discord logs
# Example: https://admin.example.com
FRONTEND_URL=http://localhost:3000

# Use secure cookies (set to false for local HTTP development)
SECURE_COOKIE=true
CORS_ORIGINS=http://localhost:3000

# Database connection options
DATABASE_REQUIRE_SSL=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# SMTP options (leave empty if not using email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Optional: Health check channel ID (0 = disabled)
HEALTH_CHANNEL_ID=0

# Optional: Bump reminder channel ID (0 = disabled)
BUMP_CHANNEL_ID=0

# Frontend build-time API destination
API_URL=http://localhost:8000
